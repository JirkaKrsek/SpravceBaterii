@page "/zarizeni"
@using Microsoft.AspNetCore.Components.Authorization
@using SpravceBaterii.Components.Shared
@using SpravceBaterii.Data.Models
@using SpravceBaterii.Services
@using SpravceBaterii.Services.Tools

@inject DeviceService DeviceService
@inject ExceptionHandlerService ExceptionHandlerService
@inject ModalNavigationService ModalNavigationService

<PageTitle>Správce baterií - Zařízení</PageTitle>

<h1>Zařízení</h1>

<!--Zobrazení chybové hlášky pokud je vyplněna-->
@if (!string.IsNullOrEmpty(errorMessage))
{
	<p class="error-message">@errorMessage</p>
}

@if (isDataLoaded)
{
	@if (ModalNavigationService.GetCurrentComponent()?.ComponentType == typeof(DeviceDetail))
	{
		<div class="overlay">
			<div class="overlay-content">
				<DeviceDetail DeviceId="@ModalNavigationService.GetCurrentComponent()!.SelectedId!.Value"
							  BatteryDetail="@(batteryId => ModalNavigationService.Open(typeof(BatteryDetail), batteryId))"
							  EditDevice="@(deviceId => ModalNavigationService.Open(typeof(DeviceForm), deviceId))"
							  InsertBattery="@(deviceId => ModalNavigationService.Open(typeof(InsertBatteryToDevice), deviceId))"
							  SetLocation="@(deviceId => ModalNavigationService.Open(typeof(SetLocation), deviceId))"
							  Deleted="@(async () => { ModalNavigationService.CloseAll(); ModalNavigationService.MarkForReload(); })"
							  Cancel="@(async (dataChanged) => { ModalNavigationService.Close(); if (dataChanged) {ModalNavigationService.MarkForReload();} })"></DeviceDetail>
			</div>
		</div>
	}
	else if (ModalNavigationService.GetCurrentComponent()?.ComponentType == typeof(BatteryDetail))
	{
		<div class="overlay">
			<div class="overlay-content">
				<BatteryDetail BatteryId="@ModalNavigationService.GetCurrentComponent()!.SelectedId!.Value"
							   EditBattery="@(batteryId => ModalNavigationService.Open(typeof(BatteryForm), batteryId))"
							   Deleted="@(async () => { ModalNavigationService.CloseAll(); ModalNavigationService.MarkForReload(); })"
							   Cancel="@(async (dataChanged) => { ModalNavigationService.Close(); if (dataChanged) {ModalNavigationService.MarkForReload();} })"></BatteryDetail>
			</div>
		</div>
	}
	else if (ModalNavigationService.GetCurrentComponent()?.ComponentType == typeof(BatteryForm))
	{
		<div class="overlay">
			<div class="overlay-content">
				<BatteryForm BatteryToUpdateId="@ModalNavigationService.GetCurrentComponent()?.SelectedId"
							 BatterySaved="@(() => { ModalNavigationService.Close(); ModalNavigationService.MarkForReload();})"
							 Deleted="@(async () => { ModalNavigationService.CloseAll(); ModalNavigationService.MarkForReload(); })"
							 Cancel="@(() => ModalNavigationService.Close())"></BatteryForm>
			</div>
		</div>
	}
	else if (ModalNavigationService.GetCurrentComponent()?.ComponentType == typeof(DeviceForm))
	{
		<div class="overlay">
			<div class="overlay-content">
				<DeviceForm DeviceToUpdateId="@ModalNavigationService.GetCurrentComponent()?.SelectedId"
							DeviceSavedShowDeviceDetail="@(async (deviceId) => {ModalNavigationService.Close(); ModalNavigationService.MarkForReload(); ModalNavigationService.Open(typeof(DeviceDetail), deviceId);})"
							DeviceSaved="@(async () => {ModalNavigationService.Close(); ModalNavigationService.MarkForReload(); })"
							Deleted="@(async () => { ModalNavigationService.CloseAll(); ModalNavigationService.MarkForReload(); })"
							Cancel="@(async () => ModalNavigationService.Close())"></DeviceForm>
			</div>
		</div>
	}
	else if (ModalNavigationService.GetCurrentComponent()?.ComponentType == typeof(InsertBatteryToDevice))
	{
		<div class="overlay">
			<div class="overlay-content">
				<InsertBatteryToDevice DeviceId="@ModalNavigationService.GetCurrentComponent()!.SelectedId!.Value"
									   EditBattery="@(batteryId => ModalNavigationService.Open(typeof(BatteryForm), batteryId))"
									   Saved="@(async () => { ModalNavigationService.Close(); ModalNavigationService.MarkForReload(); })"
									   Cancel="@(async () => ModalNavigationService.Close())"></InsertBatteryToDevice>
			</div>
		</div>
	}
	else if (ModalNavigationService.GetCurrentComponent()?.ComponentType == typeof(SetLocation))
	{
		<div class="overlay">
			<div class="overlay-content">
				<SetLocation DeviceId="@ModalNavigationService.GetCurrentComponent()!.SelectedId!.Value"
							 Saved="@(async () => { ModalNavigationService.Close(); ModalNavigationService.MarkForReload(); })"
							 Cancel="@(async () => ModalNavigationService.Close())"></SetLocation>
			</div>
		</div>
	}
	else
	{
		<button @onclick="() => ModalNavigationService.Open(typeof(DeviceForm), null)">Přidat nové zařízení</button>
	}
}

<hr>

<h2>Seznam všech zařízení</h2>

@if (DeviceList.Count < 1)
{
	<h3>Žádná uložená zařízení</h3>
}
else
{
	<div class="table-container">
	<table class="selectable">
		<thead>
			<tr>
				<th>Název zařízení</th>
				<th>Popis zařízení</th>
				<th>Počet baterií (vloženo / max)</th>
				<th>Nejbližší datum expirace vložených baterií</th>
				<th>Do konce expirace zbývá dní</th>
				<th>Výrobce</th>
				<th>Umístění</th>
			</tr>
		</thead>
		<tbody>
			@foreach (Device device in DeviceList)
			{
				<tr @onclick="() => ModalNavigationService.Open(typeof(DeviceDetail), device.Id)" title="Zobrazit detail">
					<td>@device.Name</td>
					<td><textarea disabled>@device.Description</textarea></td>
					<td>@(device.Batteries?.Sum(b => b.Count) ?? 0) / @device.BatteryCount</td>

					@{
						DateOnly? date = GetExpirationDate(device);
						<td>@(date.HasValue? date.Value.ToShortDateString() : "")</td>

						BatteryStatus StatusExpirationDate = SetRemainingDaysToExpirate(device);
						<td class="@(StatusExpirationDate?.CssClass ?? "")">@(StatusExpirationDate?.Days?.ToString() ?? "")</td>
					}

					<td>@device.Manufacturer</td>
					<td>@device.Location?.Name</td>
				</tr>
			}
		</tbody>
	</table>
	</div>
}

@code {
	private string errorMessage = "";
	private bool isDataLoaded = false;
	private List<Device> DeviceList = new();
	private BatteryStatusEvaluator batteryStatusEvaluator = new();

	/// <summary>
	/// Při načtení stránky se zavolá načtení dat
	/// </summary>
	/// <returns>Asynchronní operace</returns>
	protected override async Task OnInitializedAsync()
	{
		ModalNavigationService.Reset();

		await LoadDeviceList();
	}

	/// <summary>
	/// Po vykreslení stránky se zkontroluje, zda nejsou potřeba znovunačíst data
	/// </summary>
	/// <param name="firstRender">bool, zda se stránka vykresluje poprvé</param>
	/// <returns>Asynchronní operace</returns>
	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (ModalNavigationService.ShouldReload())
		{
			await LoadDeviceList();
			ModalNavigationService.Reset();

			//Aktualizace UI
			StateHasChanged();
		}
	}
	/// <summary>
	/// Načtení informací o zařízeních uživatele z databáze
	/// </summary>
	/// <returns>Asynchronní operace</returns>
	private async Task LoadDeviceList()
	{
		try
		{
			DeviceList = await DeviceService.GetDevices();
			DeviceList = DeviceList.OrderBy(d => d.Name).ToList();

			isDataLoaded = true;
		}
		catch (Exception ex)
		{
			errorMessage = ExceptionHandlerService.HandleException(ex);
		}
	}

	private DateOnly? GetExpirationDate(Device device)
	{
		return device.Batteries?
					.Where(b => b.DisposableBattery?.ExpirationDate != null)
					.Min(b => b.DisposableBattery?.ExpirationDate);
	}

	/// <summary>
	/// Získání stavu baterie podle zbývajících dní do konce expirace
	/// </summary>
	/// <param name="device">Zařízení</param>
	/// <returns>Status baterie</returns>
	private BatteryStatus SetRemainingDaysToExpirate(Device device)
	{
		DateOnly? date = GetExpirationDate(device);
		if (date is not null)
		{
			BatteryStatus status = batteryStatusEvaluator.RemainingDaysToExpirate(date.Value);
			return status;
		}
		return new BatteryStatus();
	}
}
