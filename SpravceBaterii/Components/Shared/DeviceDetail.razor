@using Microsoft.AspNetCore.Components.Authorization
@using SpravceBaterii.Data.Models
@using SpravceBaterii.Services
@using SpravceBaterii.Services.Tools

@inject BatteryService BatteryService
@inject DeviceService DeviceService
@inject ExceptionHandlerService ExceptionHandlerService
@inject ModalNavigationService ModalNavigationService

<div class="component-header">
	<h2>
		Detail zařízení
		@if (isDataLoaded)
		{
			@(": " + device.Name)
		}
	</h2>
</div>

<!--Zobrazení chybové hlášky pokud je vyplněna-->
@if (!string.IsNullOrEmpty(errorMessage))
{
	<p class="error-message">@errorMessage</p>
}

<!--Zobrazení potvrzovacího dialogu-->
<ConfirmDialog @ref="confirmDialog" />

@if (isDataLoaded)
{
	<table>
		<tr>
			<td>Název zařízení: </td>
			<td>@device.Name</td>
		</tr>
		<tr>
			<td>Popis zařízení: </td>
			<td><textarea readonly>@device.Description</textarea></td>
		</tr>
		<tr>
			<td>Počet baterií (vloženo / max): </td>
			@{
				int insertedCount = device.Batteries?.Sum(b => b.Count) ?? 0;

				if (insertedCount > 0 && insertedCount < device.BatteryCount)
				{
					<td class="count-warning">@insertedCount / @device.BatteryCount - Zařízení aktuálně neobsahuje dostatek baterií</td>
				}
				else
				{
					<td>@insertedCount / @device.BatteryCount</td>
				}
			}
		</tr>
		<tr>
			<td>Typ baterií: </td>
			<td>@device.BatteryType.Name</td>
		</tr>
		<tr>
			<td>Výrobce: </td>
			<td>@device.Manufacturer</td>
		</tr>
		<tr>
			<td>Umístění: </td>
			<td>@device.Location?.Name</td>
		</tr>
	</table>
}
else
{
	<h2>Detail Zařízení</h2>
}

<hr>

@if (Batteries.Count < 1)
{
	<h3>V tomto zařízení není vložena žádná baterie</h3>
}
else
{
	<h3>Vložené baterie:</h3>

	<div class="table-container">
		<table class="selectable">
			<thead>
				<tr>
					<th>Počet</th>
					<th>Označení</th>
					<th>Popis</th>
					<th>Typ</th>
					<th>Datum expirace</th>
					<th>Do konce expirace zbývá dní</th>
					<th>Datum vložení</th>
					<th>Předpokládaná doba výdrže (ve dnech)</th>
					<th>Zbývající předpokládaná životnost</th>
					<th>Akce</th>
				</tr>
			</thead>
			<tbody>
				@foreach (Battery battery in Batteries)
				{
					<tr @onclick="() => ModalNavigationService.Open(typeof(BatteryDetail), battery.Id)" title="Zobrazit detail">
						<td>@battery.Count</td>
						<td>@battery.BatteryType.Name</td>
						<td><textarea disabled>@battery.Description</textarea></td>
						@if (battery.IsRechargeable)
						{
							<td>Nabíjecí</td>
							<td></td>
							<td></td>
						}
						else
						{
							<td>Jednorázová</td>
							<td>@(battery.DisposableBattery?.ExpirationDate.ToShortDateString() ?? "")</td>
							BatteryStatus batteryStatusExpirationDate = SetRemainingDaysToExpirate(battery);
							<td class="@(batteryStatusExpirationDate?.CssClass ?? "")">@(batteryStatusExpirationDate?.Days?.ToString() ?? "")</td>
						}
						<td>@(battery.InsertionDate?.ToShortDateString() ?? "")</td>
						<td>@(battery.ExpectedLifespan?.ToString() ?? "")</td>
						@{
							BatteryStatus batteryStatusExpectedLifeSpan = SetRemainingDaysToExpectedLife(battery);
							<td class="@(batteryStatusExpectedLifeSpan?.CssClass ?? "")">@(batteryStatusExpectedLifeSpan?.Days?.ToString() ?? "")</td>
						}

						<td>
							<button @onclick:stopPropagation="true" @onclick="async () => { selectedBatteryId = battery.Id; await EjectBatteryFromDevice(); }" title="">Vysunout / odstranit</button>
						</td>
					</tr>
				}
			</tbody>
		</table>
	</div>
}

<hr>

<div class="action-buttons">
	<button @onclick="() => ModalNavigationService.Open(typeof(DeviceForm), device.Id)">Upravit</button>

	@if ((device.Batteries?.Sum(b => b.Count) ?? 0) < device.BatteryCount)
	{
		<button @onclick="() => ModalNavigationService.Open(typeof(InsertBatteryToDevice), device.Id)">Vložit baterii</button>
	}

	@if (device.LocationId is null)
	{
		<button @onclick="() => ModalNavigationService.Open(typeof(SetLocation), device.Id)">Nastavit umístění</button>
	}
	else
	{
		<button @onclick="() => ModalNavigationService.Open(typeof(SetLocation), device.Id)">Změnit umístění</button>
	}

	@if (device.Batteries?.Count > 0)
	{
		<button type="button" @onclick="async () => await EjectBatteriesFromDevice()">Vysunout / odstranit všechny baterie</button>
	}

	<button type="button" @onclick="async () => await DeleteDevice()">Odstranit</button>
</div>

@code {
	/// <summary>
	/// Vstupní parametr - ID položky pro její načtení
	/// </summary>
	[Parameter]
	public int ItemId { get; set; }


	private string errorMessage = "";
	private ConfirmDialog confirmDialog = default!;
	private int? selectedBatteryId = null;
	private bool isDataLoaded = false;

	private Device device = new();
	private List<Battery> Batteries = new();

	private BatteryStatusEvaluator batteryStatusEvaluator = new();


	/// <summary>
	/// Načtení potřebných dat při zobrazení komponenty
	/// </summary>
	/// <returns>Asynchronní operace</returns>
	protected override async Task OnInitializedAsync()
	{
		await LoadDeviceList();
	}

	/// <summary>
	/// Načtení potřebných informací z databáze
	/// </summary>
	/// <returns>Asynchronní operace</returns>
	private async Task LoadDeviceList()
	{
		try
		{
			device = await DeviceService.GetUserDeviceByIdWithDetails(ItemId);
			Batteries = await BatteryService.GetUserBatteriesByDeviceId(device.Id);

			isDataLoaded = true;
		}
		catch (Exception ex)
		{
			errorMessage = ExceptionHandlerService.HandleException(ex);
		}
	}

	/// <summary>
	/// Odstranění vybraného zařízení z databáze
	/// </summary>
	/// <returns>Asynchronní operace</returns>
	private async Task DeleteDevice()
	{
		try
		{
			if (await confirmDialog.Show("Opravdu chcete toto zařízení odstranit z evidence?", new() { "Odstranit", "Zrušit" }) == 1)
			{
				if (device.Batteries?.Count > 0)
				{
					if (await confirmDialog.Show("Chcete baterie z tohoto zařízení ponechat v evidenci nebo je ihned odstranit?", new() { "Ponechat v evidenci", "Odstranit" }) == 1)
					{
						foreach (Battery battery in device.Batteries)
						{
							await BatteryService.EjectBatteryFromDevice(battery.Id, device.Name);
						}
					}
					else
					{
						foreach (Battery battery in device.Batteries)
						{
							await BatteryService.DeleteBatteryById(battery.Id);
						}
					}
				}

				await DeviceService.DeleteDeviceById(ItemId);

				ModalNavigationService.MarkForReload();
				ModalNavigationService.CloseAll();
			}
		}
		catch (Exception ex)
		{
			errorMessage = ExceptionHandlerService.HandleException(ex);
		}
	}

	/// <summary>
	/// Vysunutí / smazání všech baterií v zařízení
	/// </summary>
	/// <returns>Asynchronní operace</returns>
	private async Task EjectBatteriesFromDevice()
	{
		try
		{
			if (device.Batteries?.Count > 0)
			{
				int result = await confirmDialog.Show("Chcete všechny baterie vysunout a ponechat v evidenci nebo vysunout a ihned odstranit z evidence?", new() { "Vysunout a ponechat", "Vysunout a odstranit", "Zrušit" });
				if (result == 1)
				{
					foreach (Battery battery in device.Batteries)
					{
						await BatteryService.EjectBatteryFromDevice(battery.Id, device.Name);
					}

					ModalNavigationService.MarkForReload();

					await LoadDeviceList();
				}
				else if (result == 2)
				{
					foreach (Battery battery in device.Batteries)
					{
						await BatteryService.DeleteBatteryById(battery.Id);
					}

					ModalNavigationService.MarkForReload();

					await LoadDeviceList();
				}
			}
		}
		catch (Exception ex)
		{
			errorMessage = ExceptionHandlerService.HandleException(ex);
		}
		finally
		{
			selectedBatteryId = null;
		}
	}

	/// <summary>
	/// Vysunutí / odstranění vybrané baterie ze zařízení
	/// </summary>
	/// <returns>Asynchronní operace</returns>
	private async Task EjectBatteryFromDevice()
	{
		try
		{
			if (selectedBatteryId is null)
			{
				return;
			}

			int result = await confirmDialog.Show("Chcete tuto baterii vysunout a ponechat v evidenci nebo vysunout a ihned odstranit z evidence?", new() { "Vysunout a ponechat", "Vysunout a odstranit", "Zrušit" });
			if (result == 1)
			{
				await BatteryService.EjectBatteryFromDevice(selectedBatteryId!.Value, device.Name);

				ModalNavigationService.MarkForReload();

				await LoadDeviceList();
			}
			else if (result == 2)
			{
				await BatteryService.DeleteBatteryById(selectedBatteryId!.Value);

				ModalNavigationService.MarkForReload();

				await LoadDeviceList();
			}
		}
		catch (Exception ex)
		{
			errorMessage = ExceptionHandlerService.HandleException(ex);
		}
		finally
		{
			selectedBatteryId = null;
		}
	}

	/// <summary>
	/// Získání stavu baterie podle zbývajících dní do konce expirace
	/// </summary>
	/// <param name="battery">Baterie</param>
	/// <returns>Status baterie</returns>
	private BatteryStatus SetRemainingDaysToExpirate(Battery battery)
	{
		if (!battery.IsRechargeable && battery.DisposableBattery is not null)
		{
			return batteryStatusEvaluator.RemainingDaysToExpirate(battery.DisposableBattery.ExpirationDate);
		}
		return new BatteryStatus();
	}

	/// <summary>
	/// Získání stavu baterie podle zbývajících dní do předpokládaného data životnosti
	/// </summary>
	/// <param name="battery">Baterie</param>
	/// <returns>Status baterie</returns>
	private BatteryStatus SetRemainingDaysToExpectedLife(Battery battery)
	{
		if (battery.ExpectedLifespan is not null && battery.InsertionDate is not null)
		{
			return batteryStatusEvaluator.RemainingDaysToExpectedLife(battery.InsertionDate.Value, battery.ExpectedLifespan.Value);
		}
		return new BatteryStatus();
	}
}
